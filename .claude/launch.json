{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "firebase-hosting",
      "runtimeExecutable": "firebase",
      "runtimeArgs": ["emulators:start", "--only", "hosting"],
      "port": 5000
    },
    {
      "name": "python-http",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8000"],
      "port": 8000
    },
    {
      "name": "npx-serve",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "-l", "3000"],
      "port": 3000
    }
  ]
}
